# Copy this file to ".env.local" and fill in your Supabase project values.
# Find them in Supabase dashboard → Project Settings → API.
#
# Without these set, the app still runs fully in "local mode" (scores saved in
# the browser only) — handy for local testing before you create the account.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Password for the /admin host screen. Checked server-side (never shipped to the
# browser). Pick anything you like.
ADMIN_PASSWORD=choose-a-host-password
